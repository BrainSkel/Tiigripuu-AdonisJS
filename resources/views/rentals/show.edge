<!DOCTYPE html>
<html>
<head>
@include('partials/head')
  <link rel="stylesheet" href="/resources/css/main.css">
</head>

<body>
    @include('partials/navigation')
        <div class="container my-4">
            @if(flashMessages.has('error'))
            <div class="alert alert-error">
                {{ flashMessages.get('error') }}
            </div>
            @end
            <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 g-3">
                <div class="col bg-dark p-2">
                    <div class="images">
                        <div id="carouselExample" class="carousel slide">
                            <div class="carousel-indicators">
                                <button type="button" data-bs-target="#carouselExample" data-bs-slide-to="0"
                                    class="active" aria-current="true" aria-label="Slide 1"></button>
                                <button type="button" data-bs-target="#carouselExample" data-bs-slide-to="1"
                                    aria-label="Slide 2"></button>
                                <button type="button" data-bs-target="#carouselExample" data-bs-slide-to="2"
                                    aria-label="Slide 3"></button>
                            </div>
                            <div class="carousel-inner">
                                @each(image in rental.images)
                                <div class="carousel-item {{ image.displayOrder === 1 ? 'active' : '' }}">
                                    <img src="/storage/uploads/{{image.imageUrl}}" class="d-block w-100"
                                        alt="{{rental.itemName}}">
                                </div>
                                @endeach
                            </div>
                            <button class="carousel-control-prev" type="button" data-bs-target="#carouselExample"
                                data-bs-slide="prev">
                                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                                <span class="visually-hidden">Previous</span>
                            </button>
                            <button class="carousel-control-next" type="button" data-bs-target="#carouselExample"
                                data-bs-slide="next">
                                <span class="carousel-control-next-icon" aria-hidden="true"></span>
                                <span class="visually-hidden">Next</span>
                            </button>
                        </div>
                    </div>


                    <div class="card-body">
                        @each(category in rental.categories)
                        <span class="badge rounded-pill text-bg-secondary">{{category.name}}</span>
                        @endeach
                            <div class="d-flex justify-content-between">
                                <h3>{{rental.itemName}}</h3>
                                <small class="opacity-50 text-nowrap">Hind: {{rental.price}}€</small>
                            </div>
                            <div>Kirjeldus:
                        <p class="card-text border rounded pr-auto p-1 pt-1 pb-2 overflow-auto w-auto" style="overflow-wrap: break-word;">{{rental.description}}</p>
                        </div>
                        <p class="card-tesxt">{{rental.rentalDetail.rentalInfo}}</p>
                        <div class="d-flex gap-1 m-1 overflow-auto horizontal-scroll">
                        @if(rental.rentalDetail.instructions)
                            @each(file in rental.rentalDetail.instructions)
                            <a class="btn btn-primary" download href="/storage/uploads/{{file.instructionUrl}}">{{file.fileName}}</a>
                            @end
                            <div class="d-flex justify-content-between align-items-center">
                        @end
                        </div>

                        </div>
                    </div>
                </div>
                <div class="col">
                    @if(rental.stockAmount != 0)
                    @let(cartItem = cart?.items?.find((item) => item.productId === rental.id))
                    <form action="{{route('shopping_carts.store', {productId: rental.id })}}?_method=POST" method="POST"
                        style="display:inline" class="btn-group mx-4 input-group d-flex">
                        {{ csrfField() }}
                        <input type="hidden" name="productId" value="{{rental.id}}">

                        <input type="number" class="form-control border" aria-label="Kogus" name="quantity" placeholder="1"
                            value="1" min="1" aria-describedby="button-addon2"
                            max="{{cartItem ? rental.stockAmount - cartItem.quantity : rental.stockAmount}}">
                        <button class="btn btn-primary flex-grow-2" type="submit"
                        @if(cartItem)
                            @if(rental.stockAmount===cartItem.quantity) 
                            disabled id="button-addon2">Maksimum
                            kogus</button>

                            @else
                            id="button-addon2">Lisa
                            ostukorvi</button>
                            @end
                        @else
                            id="button-addon2">Lisa
                            ostukorvi</button>
                        @end


                    </form>
                    @else
                    <p>Hetkel otsas!</p>
                    @end

                </div>

            </div>
        
    </div>

    <script>
        const myCarouselElement = document.querySelector('#carouselExample')

        const carousel = new bootstrap.Carousel(myCarouselElement, {
            interval: 2000,
            touch: false
        })
    </script>

</body>
</html>