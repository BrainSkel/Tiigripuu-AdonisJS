                <div class="col">
                    <div class="card shadow-sm">
                        <a href="{{route('handicrafts.show', { slug: handicraft.slug })}}">
                        <img src="/storage/uploads/{{handicraft.images[0].imageUrl}}" class="card-img-top"
                            alt="{{handicraft.itemName}}">
                            </a>
                        <div class="card-body">
                            @each(category in handicraft.categories)
                            <span class="badge rounded-pill text-bg-secondary">{{category.name}}</span>
                            @endeach
                            <div class="d-flex justify-content-between overflow-hidden">
                                <h3 data-bs-toggle="tooltip" data-bs-title="Default tooltip">
                                    <a href="{{route('handicrafts.show', { slug: handicraft.slug })}} ">{{handicraft.itemName}}</a>
                                </h3>
                                <small class="opacity-50 text-nowrap">Hind: {{handicraft.price}}€</small>
                            </div>
                            <p class="card-text">{{handicraft.description}}</p>
                            <p class="card-text">{{handicraft.handicraftDetail.handicraftDetails}}</p>
